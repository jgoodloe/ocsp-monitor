# Copy to .env and adjust as needed: cp .env.example .env

# URL subpath if served behind a reverse proxy at a path (e.g. /ocsp).
# Leave empty when the app has its own (sub)domain or is served at root.
URL_PREFIX=

# How often (seconds) the scheduler looks for responders due to be checked.
SCHEDULER_INTERVAL=30

# Per-request OCSP HTTP timeout (seconds).
OCSP_TIMEOUT=30

# Number of status-history rows retained per responder.
HISTORY_LIMIT=200

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
